# Neon Postgres
# https://console.neon.tech/ — create a project, copy the pooled connection string
DATABASE_URL="postgresql://user:pass@ep-xxx.neon.tech/neondb?sslmode=require"

# Better Auth
# Generate: openssl rand -base64 32
BETTER_AUTH_SECRET=""
BETTER_AUTH_URL="http://localhost:3100"

# Resend (email delivery for OTP + weekly briefs)
# https://resend.com/api-keys
RESEND_API_KEY="re_..."
RESEND_FROM_EMAIL="noreply@yourdomain.com"

# Google OAuth (for Google Search Console API access — SEPARATE from app auth)
# https://console.cloud.google.com/apis/credentials
# Scope required: https://www.googleapis.com/auth/webmasters.readonly
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_REDIRECT_URI="http://localhost:3100/api/google/callback"

# Encryption key for storing Google refresh_tokens at rest (32 bytes hex)
# Generate: openssl rand -hex 32
GSC_TOKEN_ENCRYPTION_KEY=""

# DataForSEO (SERP Standard API — rank tracking)
# https://app.dataforseo.com/api-dashboard
DATAFORSEO_LOGIN=""
DATAFORSEO_PASSWORD=""

# Anthropic (AI brief generation + AEO Claude engine)
# https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY="sk-ant-..."

# Perplexity (AEO / LLM visibility — returns citations natively)
# https://www.perplexity.ai/settings/api
PERPLEXITY_API_KEY=""

# OpenAI (AEO / LLM visibility — optional, uses web_search tool on Responses API)
# https://platform.openai.com/api-keys
OPENAI_API_KEY=""

# Inngest (job queue)
# https://app.inngest.com/env/production/manage/signing-key
#
# IMPORTANT for local dev:
#   - Set INNGEST_DEV=1 to force the SDK into dev mode (handles "Expected server
#     kind cloud, got dev" errors when the CLI dev server can't sync your app).
#   - Leave EVENT_KEY and SIGNING_KEY empty. The local CLI generates test keys.
#
# In production: unset INNGEST_DEV, fill EVENT_KEY + SIGNING_KEY from Inngest dashboard.
INNGEST_DEV=1
INNGEST_EVENT_KEY=""
INNGEST_SIGNING_KEY=""

# Stripe — payments + subscriptions + credit packs
# https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY="sk_test_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."
# Webhook secret. In dev: `stripe listen --forward-to localhost:3100/api/stripe/webhook`
# copies a `whsec_...` line. In prod: configured per webhook in Stripe dashboard.
STRIPE_WEBHOOK_SECRET="whsec_..."
# Stripe price IDs. Create these in Stripe dashboard (test mode), copy IDs here.
# - base_monthly: 15€ recurring monthly
# - credits_50: 5€ one-time
# - credits_200: 18€ one-time
# - credits_500: 40€ one-time
STRIPE_PRICE_BASE_MONTHLY="price_..."
STRIPE_PRICE_CREDITS_50="price_..."
STRIPE_PRICE_CREDITS_200="price_..."
STRIPE_PRICE_CREDITS_500="price_..."
